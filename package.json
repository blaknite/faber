{
  "name": "@blaknite/faber",
  "version": "0.1.0",
  "description": "TUI orchestrator for autonomous coding agents",
  "type": "module",
  "bin": {
    "faber": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "build:bin": "bun build src/index.tsx --compile --outfile faber",
    "start": "bun dist/index.js"
  },
  "dependencies": {
    "@opentui/core": "^0.1.82",
    "@opentui/react": "^0.1.82",
    "execa": "^9.5.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
