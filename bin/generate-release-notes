#!/bin/bash
set -euo pipefail

# Install gh if not available
(type gh > /dev/null 2>&1) || {
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null
  apt-get update && apt-get install -y gh
}

# Resolve the previous release's commit SHA via git ls-remote so we don't
# depend on the CI agent having release tags fetched in its local git clone.
LAST_TAG="$(gh release list --repo blaknite/faber --limit 1 --json tagName -q '.[0].tagName' 2>/dev/null || true)"

if [ -n "$LAST_TAG" ]; then
  LAST_SHA="$(git ls-remote origin "refs/tags/${LAST_TAG}" | awk '{print $1}')"
fi

echo "Previous release: ${LAST_TAG:-(none)}"
echo "Previous release SHA: ${LAST_SHA:-(none)}"

if [ -n "${LAST_SHA:-}" ]; then
  COMMITS="$(git log "${LAST_SHA}..HEAD" --pretty=format:'commit %H%nauthor: %an%nsubject: %s%nbody: %b%n---' --no-merges)"
else
  # No previous release, fall back to last 50 commits
  COMMITS="$(git log -50 --pretty=format:'commit %H%nauthor: %an%nsubject: %s%nbody: %b%n---' --no-merges)"
fi

if [ -z "$COMMITS" ]; then
  echo "No commits found, skipping release notes generation"
  buildkite-agent meta-data set release-notes "No changes."
  exit 0
fi

echo "--- Commits"
git log "${LAST_SHA:-HEAD~50}..HEAD" --pretty=format:'%h %s' --no-merges
echo

# Use Buildkite's hosted LLM feature to call the Anthropic API
export ANTHROPIC_BASE_URL="${BUILDKITE_AGENT_ENDPOINT}/ai/anthropic"
export ANTHROPIC_API_KEY="${BUILDKITE_AGENT_ACCESS_TOKEN}"

PAYLOAD="$(jq -n \
  --arg commits "$COMMITS" \
  '{
    model: "claude-opus-4-5",
    max_tokens: 1024,
    messages: [
      {
        role: "user",
        content: ("Write concise GitHub release notes for the following commits. Group changes by features, fixes, and other changes. Be direct and useful to end users. Do not include a preamble or sign-off.\n\nCommits:\n" + $commits)
      }
    ]
  }')"

RESPONSE="$(curl -fsSL \
  --url "${ANTHROPIC_BASE_URL}/v1/messages" \
  --header "anthropic-version: 2023-06-01" \
  --header "content-type: application/json" \
  --header "x-api-key: ${ANTHROPIC_API_KEY}" \
  --data "$PAYLOAD")"

NOTES="$(echo "$RESPONSE" | jq -r '.content[0].text')"

echo "--- Release notes"
echo "$NOTES"

buildkite-agent meta-data set release-notes "$NOTES"
